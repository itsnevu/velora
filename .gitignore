# Claude Code local/personal overrides (where "allow always" writes rules)
.claude/settings.local.json

# OAuth tokens and credentials — must never be committed
.claude.json
*.token
*.key
*.pem
.env
.env.*

# Secrets
secrets/
credentials/

# Live desk snapshot written by the PM (contains real account state) — the sanitized
# ui/public/desk-state.example.json is shipped instead.
ui/public/desk-state.json

# Runtime control file: the dashboard "Run desk" button writes it; the PM's /loop reads it.
desk-request.json

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# OS
.DS_Store
